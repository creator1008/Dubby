# Dubby API environment template. Copy to .env and fill in — never commit
# real values. Every variable maps to a field in app/config.py.

# --- Runtime ---------------------------------------------------------------
APP_ENV=local                       # local | staging | production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
# Include deployed Pages plus Capacitor's local WebView origins.
CORS_ORIGINS=http://localhost:3000,https://localhost,capacitor://localhost

# --- Supabase ----------------------------------------------------------------
# Project URL: Supabase dashboard > Settings > API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Legacy JWT secret (Settings > API > JWT Settings). If left empty, tokens
# are verified against the project's JWKS endpoint instead (recommended for
# projects using asymmetric signing keys).
SUPABASE_JWT_SECRET=
# Service-role key. Required only when DB_BACKEND=supabase_rest.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database ------------------------------------------------------------------
# postgres       -> direct asyncpg connection (recommended on Lightsail)
# supabase_rest  -> PostgREST over HTTPS with the service-role key
DB_BACKEND=postgres
# Use the Supabase connection pooler URI (Settings > Database), SESSION mode:
# postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5

# --- Cloudflare R2 ----------------------------------------------------------------
# Cloudflare dashboard > R2 > Manage R2 API Tokens (Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dubby
# Leave empty to derive https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
PRESIGN_EXPIRES_SECONDS=3600
DOWNLOAD_EXPIRES_SECONDS=300
MULTIPART_PART_SIZE_BYTES=67108864   # 64 MiB
MAX_UPLOAD_BYTES=4294967296          # 4 GiB

# --- Worker ---------------------------------------------------------------------
WORKER_CONCURRENCY=1                 # keep 1 on small instances (Demucs RAM)
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_JOB_TIMEOUT_SECONDS=3600

# --- Pipeline ----------------------------------------------------------------------
# real -> ffmpeg/Demucs/OpenAI/ElevenLabs. mock -> offline deterministic
# stand-ins for development/tests ONLY (production refuses mock).
PIPELINE_MODE=real
# Parent dir for per-job scratch dirs. Empty -> system temp.
SCRATCH_DIR=
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Source validation limits (MVP)
MAX_SOURCE_DURATION_SECONDS=600      # 10 minutes
MAX_SOURCE_BYTES=524288000           # 500 MB
ALLOWED_SOURCE_CONTAINERS=mp4,mov,m4a,3gp,3g2,mj2,matroska,webm
PIPELINE_STEP_RETRIES=2
PIPELINE_RETRY_BACKOFF_SECONDS=2
PIPELINE_HEARTBEAT_SECONDS=20

# --- Demucs stem split ----------------------------------------------------------------
DEMUCS_MODEL=htdemucs_ft
DEMUCS_DEVICE=cpu                    # cpu | cuda
DEMUCS_JOBS=1

# --- OpenAI (Whisper ASR + GPT translation) ---------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1
TRANSLATION_MODEL=gpt-4o-mini
SPEECH_SEGMENT_MAX_SECONDS=6
TRANSLATION_BATCH_SIZE=40
TRANSLATION_TIMING_TOLERANCE=0.15

# --- ElevenLabs (voice clone + TTS) -----------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# Set to skip Instant Voice Clone and always dub with this voice id.
ELEVENLABS_VOICE_ID=
VOICE_CLONE_SAMPLE_SECONDS=60
TTS_MAX_SPEEDUP=1.6                  # cap on speeding clips up to fit slots
TTS_MIN_TEMPO=0.85
TTS_ATEMPO_MAX=1.5
# Set when Rubber Band support is installed/enabled; empty uses bounded atempo.
RUBBERBAND_PATH=

# --- Speaker diarization ----------------------------------------------------
# OpenAI uses the configured API key; mock is offline/test-only.
DIARIZATION_PROVIDER=openai          # disabled | mock | openai | pyannote
DIARIZATION_MODEL=gpt-4o-transcribe-diarize
PYANNOTE_AUTH_TOKEN=
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
SPEAKER_SAMPLE_SECONDS=30

# --- Premium lip sync -------------------------------------------------------
LIPSYNC_PROVIDER=disabled            # disabled | mock | sync
SYNC_API_KEY=
SYNC_BASE_URL=https://api.sync.so
SYNC_MODEL=lipsync-2
SYNC_TIMEOUT_SECONDS=900
SYNC_POLL_INTERVAL_SECONDS=5
LIPSYNC_COGS_MINUTES_MULTIPLIER=2.0

# --- Product ----------------------------------------------------------------------
SIGNUP_CREDIT_MINUTES=10
DUB_COGS_MINUTES_MULTIPLIER=1.0

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=
STRIPE_CREDIT_PACK_PRICE_ID=
STRIPE_SUBSCRIPTION_MINUTES=60
STRIPE_CREDIT_PACK_MINUTES=30
CHECKOUT_SUCCESS_URL=http://localhost:3000/app/billing/?checkout=success
CHECKOUT_CANCEL_URL=http://localhost:3000/app/billing/?checkout=cancelled

# --- RevenueCat -------------------------------------------------------------
# Set the same exact opaque value in RevenueCat webhook Authorization header.
REVENUECAT_WEBHOOK_AUTH_HEADER=
# Product mapping takes precedence; entitlement is the fallback.
# Example only — replace identifiers with RevenueCat dashboard values.
REVENUECAT_PRODUCT_CREDIT_MINUTES=starter_monthly=60,credits_30=30
REVENUECAT_ENTITLEMENT_CREDIT_MINUTES=starter=60
