# Local OpenAI/ElevenLabs web flow (recommended while developing without SaaS):
NEXT_PUBLIC_LOCAL_PIPELINE=true
NEXT_PUBLIC_LOCAL_PIPELINE_ORIGIN=http://localhost:8002
# Leave empty for local pipeline mode. Set only when using the full FastAPI + Supabase stack.
# NEXT_PUBLIC_API_ORIGIN=http://localhost:8000

# Supabase publishable/anon key only — never put service-role or secret keys here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_REVENUECAT_ANDROID_API_KEY=
NEXT_PUBLIC_REVENUECAT_IOS_API_KEY=

# Provider keys used by api/app/local_step12.py and the FastAPI worker
PIPELINE_MODE=auto
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# FFMPEG_PATH=
